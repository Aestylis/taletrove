    "settlement-hook": {
        "pattern": "{hooks}",
        "hooks": [
            "The local wells have all run dry overnight.",
            "A famous bard disappeared while staying at the local inn.",
            "Strange lights are seen nightly in the nearby abandoned tower.",
            "The town's livestock is being found with strange, runic marks.",
            "A mysterious merchant is selling items that grant wishes, for a price.",
            "Every resident has had the exact same dream for three nights.",
            "The statues in the town square have begun to move.",
            "A dense, unnatural fog has surrounded the village for a week.",
            "The town bell rings every hour, but the bell-tower is empty.",
            "A local child has begun speaking a forgotten, ancient language.",
            "The harvest was plentiful, but everything tastes of copper.",
            "An earthquake revealed a set of stairs beneath the tavern.",
            "The shadows of the villagers are detached and wandering.",
            "A massive, sleeping beast has blocked the only road in.",
            "All the birds in the area have suddenly stopped singing."
        ]
    },
    "env-detail": {
        "pattern": "{details}",
        "details": [
            "The air here is thick with the scent of ozone and pine.",
            "Ghostly whispers echo from the crumbling stone walls.",
            "Strange, bioluminescent fungi pulse with a rhythmic blue light.",
            "Gravity feels slightly weaker here, making footsteps feel light.",
            "The ground is covered in a layer of fine, crystalline frost.",
            "The trees here grow in perfect, geometric patterns.",
            "A persistent, low-frequency hum vibrates through the soles of your boots.",
            "The water in the stream flows backwards against the wind.",
            "Everything here is cast in a permanent, golden twilight glow.",
            "The wind sounds like a distant choir mourning a lost king.",
            "Tiny, metallic beetles scurry between the obsidian pebbles.",
            "The scent of old parchment and woodsmoke lingers in the air.",
            "Mirrors here reflect the room as it looked a century ago.",
            "A fine, silver mist clings to the ground even in direct sunlight.",
            "The silence here is so absolute it makes your ears ring."
        ]
    }
